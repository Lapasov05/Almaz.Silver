# ============================================================
# Almaz AI Seller + CRM — muhit o'zgaruvchilari
# Ishlatish: `cp .env.example .env` va qiymatlarni to'ldiring.
# TZ 15-bo'lim: secretlar repo'ga tushmaydi (.env .gitignore'da).
# ============================================================

# --- Umumiy ---
APP_NAME="Almaz AI Seller CRM"
ENVIRONMENT=development
DEBUG=true

# --- PostgreSQL ---
POSTGRES_USER=almaz
POSTGRES_PASSWORD=almaz
POSTGRES_DB=almaz
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- JWT (TZ 15-bo'lim) — prod'da ALBATTA almashtiring ---
JWT_SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
PERMISSION_CACHE_TTL=300

# --- RabbitMQ / Celery ---
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO / S3 ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=almaz

# --- Boshlang'ich Super Admin (seed) ---
SEED_ADMIN_EMAIL=admin@almazsilver.uz
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Super Admin

# --- Telegram Bot API (TZ 3/15) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=dev-telegram-secret
TELEGRAM_API_BASE_URL=https://api.telegram.org

# --- Instagram / Meta Graph API (TZ 3/15) ---
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN=dev-verify-token
INSTAGRAM_PAGE_ACCESS_TOKEN=
INSTAGRAM_GRAPH_VERSION=v21.0
INSTAGRAM_GRAPH_BASE_URL=https://graph.facebook.com

# Celery: broker'siz inline ishlash (faqat test/dev)
CELERY_TASK_ALWAYS_EAGER=false

# --- AI / LLM (TZ 7) ---
# LLM_PROVIDER: openai | fake | none. Kalit bo'lmasa AI jim turadi.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_DEFAULT_MODEL=gpt-4o
AI_DEFAULT_TEMPERATURE=0.7
AI_MEMORY_MESSAGE_COUNT=15
AI_MAX_TOOL_ITERATIONS=6

# --- Checkout / lokatsiya (TZ 11) ---
PUBLIC_BASE_URL=http://localhost:8000
CHECKOUT_TOKEN_EXPIRY_HOURS=24

# --- CORS (frontend ulanishi) ---
# Vergul bilan: dev + PROD frontend domeni. Oxirida "/" QO'YMANG.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,https://almaz-steel.vercel.app
# Ixtiyoriy regex (barcha subdomenlar uchun), masalan: https://.*\.cognilabs\.org
CORS_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=true

# --- API hujjatlari (/docs, /redoc, /openapi.json) login/parol ---
DOCS_AUTH_ENABLED=true
DOCS_USERNAME=admin
DOCS_PASSWORD=almaz-docs

# --- Hardening (TZ 15/16/17, Faza 7) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_WEBHOOK_PER_MIN=240
RATE_LIMIT_DEFAULT_PER_MIN=120
# Proaktiv qayta jalb (IG 24h oynasi) — Celery beat
REENGAGEMENT_ENABLED=false
REENGAGEMENT_INTERVAL_MINUTES=30
REENGAGEMENT_INACTIVITY_MINUTES=120
REENGAGEMENT_WINDOW_HOURS=24
